{
  "manifest_version": 3,
  "name": "Transparent websites",
  "version": "1.0",
  "description": "Automatically generates css and injects it to make websites look transparent.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scanner.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Toggle Transparency"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "transparent-websites@nullbyte.rip",
      "strict_min_version": "109.0"
    },
    "data_collection_permissions": {
      "is_used": false
    }
  }
}